{
  "name": "entity-generator",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "node scripts/generate-version.js && next build --turbopack",
    "start": "next start",
    "scan": "next dev & npx react-scan@latest localhost:3000",
    "version": "node scripts/generate-version.js",
    "vercel-build": "node scripts/generate-version.js && prisma generate && prisma migrate deploy && next build",
    "test": "vitest",
    "test:run": "vitest run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "validate": "npm run test:run && npm run lint && npm run format:check",
    "postinstall": "prisma generate",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/language": "6.12.3",
    "@codemirror/state": "6.6.0",
    "@codemirror/view": "6.41.1",
    "@lezer/highlight": "1.2.3",
    "@prisma/client": "^6.19.3",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@types/prismjs": "^1.26.6",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@uiw/react-codemirror": "^4.25.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-php-generator": "^0.1.0",
    "jszip": "^3.10.1",
    "lucide-react": "^1.14.0",
    "nanoid": "^5.1.11",
    "next": "^16.2.4",
    "next-themes": "^0.4.6",
    "node-sql-parser": "^5.4.0",
    "pluralize": "^8.0.0",
    "prismjs": "^1.30.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-syntax-highlighter": "^16.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "thememirror": "^2.0.1",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.4",
    "@types/node": "^25.6.0",
    "@types/node-sql-parser": "^1.1.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-unused-imports": "^4.4.1",
    "husky": "^9.1.7",
    "prettier": "3.8.3",
    "prisma": "^6.19.3",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "overrides": {
      "@codemirror/language": "6.12.3",
      "@codemirror/state": "6.6.0",
      "@codemirror/view": "6.41.1",
      "@lezer/highlight": "1.2.3",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
